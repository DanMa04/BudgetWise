{
  "name": "kallio-extension",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "node build.js --browser=chrome",
    "build:firefox": "node build.js --browser=firefox",
    "dev": "node build.js --browser=chrome --watch",
    "dev:firefox": "node build.js --browser=firefox --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "esbuild": "^0.25.0",
    "jsdom": "^25.0.1",
    "typescript": "~5.7.0",
    "vitest": "^3.0.0"
  }
}
